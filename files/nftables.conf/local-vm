#!/usr/sbin/nft -f

table inet firewall
delete table inet firewall

table inet firewall {
	chain input {
		type filter hook input priority filter; policy drop;
		ct state established,related counter accept
		ct state invalid counter drop
		iifname "lo" counter accept
		ip protocol icmp icmp type echo-request limit rate 100/second counter accept
		ip6 nexthdr icmpv6 icmpv6 type { echo-request, nd-router-advert, nd-router-solicit, nd-neighbor-advert, nd-neighbor-solicit } limit rate 100/second counter accept
		# ssh
		ct state new tcp dport 2200 meter ssh_rate { ip saddr limit rate 5/minute burst 10 packets } counter accept
		ct state new tcp dport 2200 counter log prefix "ssh-rate-limit: " drop
		# nginx
		ct state new tcp dport 80 meter http_rate { ip saddr limit rate 100/minute burst 200 packets } counter accept
		ct state new tcp dport 80 counter log prefix "http-rate-limit: " drop
		ct state new tcp dport 443 meter https_rate { ip saddr limit rate 100/minute burst 200 packets } counter accept
		ct state new tcp dport 443 counter log prefix "https-rate-limit: " drop
		counter comment "packets reached the end of the chain"
	}

	chain forward {
		type filter hook forward priority filter; policy drop;
        ct state established,related counter accept
		ct state invalid counter drop
		# docker
		# iifname enp0s1 ip daddr 172.17.0.0/12 ct state new ct original proto-dst 80 meter docker_http_rate { ip saddr limit rate 100/minute burst 200 packets } counter accept
		# iifname enp0s1 ip daddr 172.17.0.0/12 ct state new ct original proto-dst 80 counter log prefix "docker-http-rate-limit: " drop
		# iifname enp0s1 ip daddr 172.17.0.0/12 ct state new ct original proto-dst 443 meter docker_https_rate { ip saddr limit rate 100/minute burst 200 packets } counter accept
		# iifname enp0s1 ip daddr 172.17.0.0/12 ct state new ct original proto-dst 443 counter log prefix "docker-https-rate-limit: " drop
		# ngircd
		iifname enp0s1 ip daddr 172.17.0.0/12 ct state new ct original proto-dst 6697 meter docker_ircd_6667_rate { ip saddr limit rate 100/minute burst 200 packets } counter accept
		iifname enp0s1 ip daddr 172.17.0.0/12 ct state new ct original proto-dst 6697 counter log prefix "docker-ircd-6667-rate-limit: " drop
		counter comment "packets reached the end of the chain"
	}
}