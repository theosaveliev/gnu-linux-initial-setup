---
services:
  dhtnode:
    image: "{{ dhtnode_image }}"
    container_name: dhtnode
    ports:
      - "{{ dhtnode_port }}:{{ dhtnode_port }}/udp"
    command:
      - "/usr/bin/dhtnode"
      - "-b"
      - "{{ dhtnode_bootstrap_node }}"
      - "-p"
      - "{{ dhtnode_port }}"
      - "-n"
      - "{{ dhtnode_network_id }}"
      - "-D"
      - "-v"
      - "-s"
    network_mode: host
    healthcheck:
      test: ["CMD-SHELL", "grep -q ':{{ "%04X" | format(dhtnode_port | int) }} ' /proc/net/udp"]
      interval: 30s
      timeout: 2s
      retries: 3
      start_period: 10s
    restart: always
...
