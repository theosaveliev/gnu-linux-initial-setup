---
services:
  coturn:
    image: "{{ coturn_image }}"
    container_name: coturn
    volumes:
      - type: bind
        source: ./config
        target: /etc/coturn
    network_mode: host
    healthcheck:
      test: ["CMD-SHELL", "grep -q ':{{ "%04X" | format(coturn_port | int) }} ' /proc/net/tcp && grep -q ':{{ "%04X" | format(coturn_port | int) }} ' /proc/net/udp"]
      interval: 30s
      timeout: 2s
      retries: 3
      start_period: 10s
    restart: always
...
