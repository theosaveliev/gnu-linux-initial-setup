---
services:
  "{{ service.name }}":
    image: "{{ images.ngircd }}"
    container_name: "{{ service.name }}"
    environment:
      - PUID={{ docker_run_as.user }}
      - PGID={{ docker_run_as.group }}

    volumes:
      - "./config:/config:rw"
      - "./certs:/certs:ro"

    ports:
{% if service.port is defined %}
      - "{{ service.port }}:{{ service.port }}"
{% endif %}
{% if service.tls_port is defined %}
      - "{{ service.tls_port }}:{{ service.tls_port }}"
{% endif %}

    networks:
      "{{ service.name }}-net":
        aliases:
          - "{{ service.domain }}"

    cap_drop:
      - ALL
    cap_add:
      - CHOWN
      - FOWNER
      - SETUID
      - SETGID
      - DAC_OVERRIDE
    security_opt:
      - no-new-privileges

    healthcheck:
      test: ["CMD-SHELL", "grep -q ':{{ "%04X" | format(service.port | int) }} ' /proc/net/tcp"]
      interval: 30s
      timeout: 2s
      retries: 3
      start_period: 10s

    restart: always

networks:
  "{{ service.name }}-net":
    name: "{{ service.name }}-net"
...
