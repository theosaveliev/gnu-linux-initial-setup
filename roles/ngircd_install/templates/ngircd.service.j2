[Unit]
Description=ngircd
Requires=docker.service
After=docker.service

[Service]
Type=simple
WorkingDirectory={{ ansible_facts['user_dir'] }}/ngircd
ExecStart={{ ngircd_docker_cli }} compose -f compose.yaml up
ExecStop={{ ngircd_docker_cli }} compose -f compose.yaml down
Restart=always

[Install]
WantedBy=multi-user.target