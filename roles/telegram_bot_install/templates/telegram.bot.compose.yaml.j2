---
services:
  "{{ service.name }}":
    image: "{{ images.telegram_bot }}"
    container_name: "{{ service.name }}"
    user: "{{ docker_run_as.user }}"
    group_add:
      - "{{ docker_run_as.group }}"

    volumes:
      - "./{{ service.session_dir }}:/app/{{ service.session_dir }}:rw"

    env_file:
      - "./telegram.env"

    ports:
      - "{{ service.port }}:{{ service.port }}"

    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges

    healthcheck:
      test: ["CMD", "curl", "-sf", "http://localhost:{{ service.port }}/health"]
      interval: 10s
      timeout: 2s
      retries: 3
      start_period: 10s

    restart: always
...
