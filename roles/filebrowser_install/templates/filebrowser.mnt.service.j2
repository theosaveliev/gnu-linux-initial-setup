[Unit]
Description={{ filebrowser_name }}-mnt
Requires=docker.service
After=docker.service

[Service]
Type=simple
WorkingDirectory={{ ansible_facts['user_dir'] }}/{{ filebrowser_name }}
ExecStart={{ docker_cli }} compose -f compose-mnt.yaml up
ExecStop={{ docker_cli }} compose -f compose-mnt.yaml down
Restart=always

[Install]
WantedBy=multi-user.target
