---
services:
  "{{ filebrowser_name }}-mnt":
    image: "ubuntu:noble"
    container_name: "{{ filebrowser_name }}-mnt"
    volumes:
      - "{{ filebrowser_name }}-database:/database"
      - "{{ filebrowser_name }}-data:/data"

    user: "{{ docker_run_as.user }}"
    group_add:
      - "{{ docker_run_as.group }}"

    entrypoint: 
      - sleep
      - infinity

    healthcheck:
      test: ["CMD-SHELL", "exit 0"]

    restart: always

volumes:
  "{{ filebrowser_name }}-database":
    name: "{{ filebrowser_name }}_{{ filebrowser_name }}-database"
    external: true

  "{{ filebrowser_name }}-data":
    name: "{{ filebrowser_name }}_{{ filebrowser_name }}-data"
    external: true
...
